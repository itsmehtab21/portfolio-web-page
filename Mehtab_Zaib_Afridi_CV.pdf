<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 560">
  <defs>
    <linearGradient id="bg2" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#111826"/>
      <stop offset="100%" stop-color="#05070A"/>
    </linearGradient>
  </defs>

  <rect width="480" height="560" fill="url(#bg2)"/>

  <!-- grid -->
  <g stroke="#1c2733" stroke-width="1">
    <path d="M0 140 H480"/>
    <path d="M0 280 H480"/>
    <path d="M0 420 H480"/>
    <path d="M160 0 V560"/>
    <path d="M320 0 V560"/>
  </g>

  <!-- terminal window -->
  <rect x="70" y="160" width="340" height="230" rx="14" fill="#0B0F16" stroke="#00F5FF" stroke-width="2"/>
  <circle cx="96" cy="186" r="5" fill="#FF3366"/>
  <circle cx="114" cy="186" r="5" fill="#FFD000"/>
  <circle cx="132" cy="186" r="5" fill="#00FF99"/>

  <g fill="#8aff8a" font-family="monospace" font-size="13">
    <text x="92" y="220">&gt; whoami</text>
    <text x="92" y="242">mehtab_zaib_afridi</text>
    <text x="92" y="270">&gt; role --current</text>
    <text x="92" y="292">SOC Analyst (in training)</text>
    <text x="92" y="320">&gt; status</text>
    <text x="92" y="342">Securing systems...</text>
  </g>

  <text x="240" y="480" text-anchor="middle" font-family="Arial, sans-serif" font-size="15"
        fill="#5b6b78">Replace with a real photo — assets/images/profile2.*</text>
</svg>
